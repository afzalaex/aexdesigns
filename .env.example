# Core runtime
NOTION_TOKEN=your_notion_integration_token
SITE_URL=https://www.aex.design

# Optional: use a Notion database for live route discovery instead of only content/route-map.json
# NOTION_DATABASE_ID=
# NOTION_HOME_PAGE_ID=

# Optional: custom Notion property names
# NOTION_SLUG_PROPERTY=Slug
# NOTION_PUBLISHED_PROPERTY=Published
# NOTION_DESCRIPTION_PROPERTY=Description

# Optional: cache and retry tuning
# NOTION_CACHE_TTL_SECONDS=900
# NOTION_MAX_RETRIES=4
# NOTION_RETRY_BASE_DELAY_MS=750
# NOTION_CHILD_BLOCK_FETCH_CONCURRENCY=4

# Optional: protect the on-demand cache revalidation endpoint
# NOTION_REVALIDATE_SECRET=replace_with_a_long_random_secret
